	<xsl:template match="/">
		<TXMLStats>
			<xsl:variable name="pnrs">
				<xsl:apply-templates select="PNRS/OTA_TravelItineraryRQ"/>
			</xsl:variable>
			<xsl:variable name="pnrs1">
				<PNRS>
					<xsl:apply-templates select="msxsl:node-set($pnrs)/PNR" mode="pnr">
						<xsl:sort data-type="text" order="ascending" select="@AL"/>
						<xsl:sort data-type="text" order="ascending" select="@DC"/>
						<xsl:sort data-type="text" order="ascending" select="@AC"/>
					</xsl:apply-templates>
				</PNRS>
			</xsl:variable>
			<xsl:variable name="als">
				<ALS>
					<xsl:apply-templates select="msxsl:node-set($pnrs1)/PNRS/PNR[1]" mode="count"/>
				</ALS>
			</xsl:variable>
			<xsl:variable name="als1">
				<ALS>
					<xsl:apply-templates select="msxsl:node-set($als)/ALS/AL" mode="al">
						<xsl:sort data-type="number" order="descending" select="@Count"/>
					</xsl:apply-templates>
				</ALS>
			</xsl:variable>
			<xsl:apply-templates select="msxsl:node-set($als1)/ALS/AL[position() &lt; 21]" mode="top"/>
			<NumberOfTickets>
				<xsl:apply-templates select="msxsl:node-set($pnrs1)/PNRS/PNR[1]" mode="tktcount">
					<xsl:with-param name="tktnum">0</xsl:with-param>
				</xsl:apply-templates>
			</NumberOfTickets>
			<NumberOfSegments>
				<xsl:apply-templates select="msxsl:node-set($pnrs1)/PNRS/PNR[1]" mode="segcount">
					<xsl:with-param name="segnum">0</xsl:with-param>
				</xsl:apply-templates>
			</NumberOfSegments>
		</TXMLStats>
	</xsl:template>
	<xsl:template match="OTA_TravelItineraryRQ">
		<xsl:variable name="pos">
			<xsl:value-of select="position()"/>
		</xsl:variable>
		<!--xsl:if test="../OTA_TravelItineraryRS[position()=$pos]/Success">
			<xsl:variable name="pnr"><xsl:value-of select="../OTA_TravelItineraryRS[position()=$pos]/TravelItinerary/ItineraryRef/@ID"/></xsl:variable>
			<xsl:if test="msxsl:node-set($recloc)/RECLOCS/RECLOC[.=$pnr]"-->
				<PNR>
					<!--xsl:attribute name="RL"><xsl:value-of select="$pnr"/></xsl:attribute-->
					<xsl:attribute name="AL"><xsl:value-of select="TPA_Extensions/PriceData/@ValidatingAirlineCode"/></xsl:attribute>
					<xsl:attribute name="DC"><xsl:value-of select="OTA_AirBookRQ/AirItinerary/OriginDestinationOptions/OriginDestinationOption[1]/FlightSegment[1]/DepartureAirport/@LocationCode"/></xsl:attribute>
					<xsl:attribute name="AC"><xsl:value-of select="OTA_AirBookRQ/AirItinerary/OriginDestinationOptions/OriginDestinationOption[1]/FlightSegment[position()=last()]/ArrivalAirport/@LocationCode"/></xsl:attribute>
					<xsl:attribute name="NT"><xsl:value-of select="count(TPA_Extensions/PNRData/Traveler)"/></xsl:attribute>
					<xsl:attribute name="NS"><xsl:value-of select="count(OTA_AirBookRQ/AirItinerary/OriginDestinationOptions/OriginDestinationOption/FlightSegment)"/></xsl:attribute>
				</PNR>
			<!--/xsl:if>
		</xsl:if-->
	</xsl:template>
	<xsl:template match="PNR" mode="pnr">
		<xsl:copy-of select="."/>
	</xsl:template>
	<xsl:template match="PNR" mode="count">
		<xsl:variable name="al"><xsl:value-of select="@AL"/></xsl:variable>
		<xsl:if test="following-sibling::PNR[1]/@AL != $al">
			<AL>
				<xsl:attribute name="AC"><xsl:value-of select="$al"/></xsl:attribute>
				<xsl:attribute name="Count"><xsl:value-of select="count(../PNR[@AL=$al])"/></xsl:attribute>
				<xsl:for-each select="../PNR[@AL=$al]">
					<CityPair>
						<xsl:attribute name="DC"><xsl:value-of select="@DC"/></xsl:attribute>
						<xsl:attribute name="AC"><xsl:value-of select="@AC"/></xsl:attribute>
					</CityPair>
				</xsl:for-each>
			</AL>
		</xsl:if>
		<xsl:apply-templates select="following-sibling::PNR[1]" mode="count">
			<xsl:with-param name="al" select="$al"/>
		</xsl:apply-templates>
	</xsl:template>
	<xsl:template match="PNR" mode="tktcount">
		<xsl:param name="tktnum"/>
		<xsl:variable name="nt"><xsl:value-of select="@NT"/></xsl:variable>
		<xsl:variable name="tot"><xsl:value-of select="$tktnum + $nt"/></xsl:variable>
		<xsl:choose>
			<xsl:when test="following-sibling::PNR[1]">
				<xsl:apply-templates select="following-sibling::PNR[1]" mode="tktcount">
					<xsl:with-param name="tktnum" select="$tot"/>
				</xsl:apply-templates>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$tot"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>
	<xsl:template match="PNR" mode="segcount">
		<xsl:param name="segnum"/>
		<xsl:variable name="ns"><xsl:value-of select="@NS"/></xsl:variable>
		<xsl:variable name="tot"><xsl:value-of select="$segnum + $ns"/></xsl:variable>
		<xsl:choose>
			<xsl:when test="following-sibling::PNR[1]">
				<xsl:apply-templates select="following-sibling::PNR[1]" mode="segcount">
					<xsl:with-param name="segnum" select="$tot"/>
				</xsl:apply-templates>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$tot"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>
	<xsl:template match="AL" mode="al">
		<xsl:copy-of select="."/>
	</xsl:template>
	<xsl:template match="AL" mode="top">
		<xsl:copy-of select="."/>
	</xsl:template>
</xsl:stylesheet>
